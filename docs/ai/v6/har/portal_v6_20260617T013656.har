            "text": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <meta name=\"quantos-build\" content=\"11137e9-index.html:1781659794-app.js:1781659805-viewmodels.js:17\" />\n  <title>QuantOS CN · 中国 A 股智能量化操作系统</title>\n  <link rel=\"stylesheet\" href=\"/portal/assets/styles.css?v=11137e9-index.html:1781659794-app.js:1781659805-viewmodels.js:17\" />\n  <link rel=\"stylesheet\" href=\"/portal/assets/quantos.css?v=11137e9-index.html:1781659794-app.js:1781659805-viewmodels.js:17\" />\n</head>\n<body data-portal-build=\"11137e9-index.html:1781659794-app.js:1781659805-viewmodels.js:17\">\n  <div id=\"login-overlay\" class=\"login-overlay\">\n    <div class=\"login-card\">\n      <h1>QuantOS CN 登录</h1>\n      <p class=\"muted\">本地开发账号 · 非生产部署</p>\n      <label for=\"login-role\">选择角色</label>\n      <select id=\"login-role\">\n        <option value=\"admin\">admin — 全部管理权限</option>\n        <option value=\"researcher\">researcher — 研究/日报/回测</option>\n        <option value=\"viewer\">viewer — 只读</option>\n        <option value=\"service_risk\">service_risk — 风险停机/恢复</option>\n        <option value=\"service_research\">service_research — 研究服务</option>\n      </select>\n      <button id=\"btn-login\" type=\"button\">登录</button>\n      <p id=\"login-error\" class=\"error hidden\"></p>\n    </div>\n  </div>\n\n  <header class=\"top-bar\" role=\"banner\">\n    <div class=\"brand\">QuantOS CN · 中国 A 股智能量化操作系统</div>\n    <div class=\"status-grid\" id=\"header-status\" aria-live=\"polite\">\n      <span class=\"pill\" id=\"role-pill\">角色: —</span>\n      <span class=\"pill\" id=\"mode-pill\">模式: —</span>\n      <span class=\"pill\" id=\"session-pill\">时段: —</span>\n      <span class=\"pill\" id=\"freshness-pill\">数据: —</span>\n      <span class=\"pill\" id=\"capital-pill\">总资金: —</span>\n      <span class=\"pill\" id=\"budget-pill\">亏损额度: —</span>\n      <span class=\"pill kill\" id=\"kill-pill\">Kill: —</span>\n      <span class=\"pill\" id=\"native-pill\">引擎: —</span>\n    </div>\n    <button id=\"btn-logout\" type=\"button\" class=\"btn-secondary\">退出</button>\n  </header>\n\n  <nav class=\"nav-tabs\" aria-label=\"主导航\">\n    <button class=\"tab active\" data-page=\"overview\" type=\"button\">总览</button>\n    <button class=\"tab\" data-page=\"market\" type=\"button\">市场中心</button>\n    <button class=\"tab\" data-page=\"reports\" type=\"button\">量化日报</button>\n    <button class=\"tab\" data-page=\"models\" type=\"button\">模型实验室</button>\n    <button class=\"tab\" data-page=\"agents\" type=\"button\">多智能体研究室</button>\n    <button class=\"tab\" data-page=\"native\" type=\"button\">原生引擎</button>\n    <button class=\"tab\" data-page=\"paper\" type=\"button\">模拟交易</button>\n    <button class=\"tab\" data-page=\"shadow\" type=\"button\">影子实盘</button>\n    <button class=\"tab\" data-page=\"risk\" type=\"button\">风险中心</button>\n    <button class=\"tab\" data-page=\"brokers\" type=\"button\">券商连接</button>\n  </nav>\n\n  <section id=\"action-log\" class=\"action-log\" aria-live=\"polite\">\n    <strong>最近操作</strong>\n    <div id=\"action-log-body\" class=\"action-log-body\">—</div>\n  </section>\n\n  <main class=\"layout\" id=\"page-overview\">\n    <section class=\"panel full\">\n      <h2>系统总览</h2>\n      <div id=\"overview-cards\" class=\"primary-view\" data-primary-view=\"overview\"></div>\n      <div id=\"overview-blockers\" class=\"blockers-panel\"></div>\n      <div id=\"overview-report\" class=\"sub-panel\"></div>\n      <div class=\"actions wrap\">\n        <button data-action=\"doctor\" type=\"button\">系统体检</button>\n        <button data-action=\"market-update\" type=\"button\">更新数据</button>\n        <button data-action=\"daily-run\" type=\"button\">生成日报</button>\n        <button data-action=\"risk-check\" type=\"button\">风险自检</button>\n        <button data-action=\"paper-start\" type=\"button\">开始模拟交易</button>\n        <button data-action=\"paper-stop\" type=\"button\">停止模拟交易</button>\n        <button data-action=\"shadow-start\" type=\"button\">开始影子实盘</button>\n        <button data-action=\"shadow-stop\" type=\"button\">停止影子实盘</button>\n        <button data-action=\"halt\" type=\"button\" class=\"danger\">紧急停机</button>\n        <button data-action=\"reset-request\" type=\"button\">申请解除停机</button>\n        <button data-action=\"reset-confirm\" type=\"button\">确认解除停机</button>\n      </div>\n    </section>\n    <section class=\"panel\">\n      <h2>vn.py 运行时 <span class=\"tag\" id=\"vnpy-mode-tag\">—</span></h2>\n      <div id=\"vnpy-status\" class=\"primary-view\" data-primary-view=\"vnpy\"></div>\n      <div class=\"actions\">\n        <button id=\"btn-vnpy-start\" type=\"button\">启动 Runtime</button>\n        <button id=\"btn-vnpy-stop\" type=\"button\">停止</button>\n      </div>\n    </section>\n    <section class=\"panel\">\n      <h2>Qlib 研究 <span class=\"tag\" id=\"qlib-mode-tag\">—</span></h2>\n      <div id=\"qlib-status\" class=\"primary-view\" data-primary-view=\"qlib\"></div>\n      <button id=\"btn-qlib-baseline\" type=\"button\">运行基线工作流</button>\n    </section>\n  </main>\n\n  <main class=\"layout hidden\" id=\"page-market\">\n    <section class=\"panel full\">\n      <h2>市场中心</h2>\n      <div id=\"market-summary\" class=\"market-banner\"></div>\n      <h3>主要指数</h3>\n      <div id=\"market-indices\" class=\"primary-view\" data-primary-view=\"market\"></div>\n      <h3>数据 Provider</h3>\n      <div id=\"market-providers\"></div>\n      <h3>数据覆盖</h3>\n      <div id=\"market-coverage\"></div>\n      <h3>任务进度</h3>\n      <div id=\"market-job\"></div>\n      <button data-action=\"market-refresh\" type=\"button\">刷新行情</button>\n      <button data-action=\"market-update-job\" type=\"button\">更新数据（异步任务）</button>\n    </section>\n  </main>\n\n  <main class=\"layout hidden\" id=\"page-reports\">\n    <section class=\"panel full\">\n      <h2>量化日报</h2>\n      <div id=\"report-detail\" class=\"primary-view\" data-primary-view=\"reports\"></div>\n      <ul id=\"report-list\" class=\"list report-list\"></ul>\n      <div class=\"actions wrap\">\n        <button data-action=\"daily-run\" type=\"button\">立即生成日报</button>\n        <button data-action=\"candidate-gate\" type=\"button\">重新运行候选门</button>\n        <button data-action=\"open-pdf\" type=\"button\">打开桌面 PDF</button>\n      </div>\n    </section>\n  </main>\n\n  <main class=\"layout hidden\" id=\"page-models\">\n    <section class=\"panel full\">\n      <h2>模型实验室</h2>\n      <div id=\"model-registry\" class=\"primary-view\" data-primary-view=\"models\"></div>\n      <div class=\"actions wrap\">\n        <button id=\"btn-qlib-baseline-models\" type=\"button\">运行基线</button>\n        <button data-action=\"backtest\" type=\"button\">运行回测</button>\n        <button data-action=\"candidate-gate\" type=\"button\">运行候选门</button>\n      </div>\n    </section>\n  </main>\n\n  <main class=\"layout hidden\" id=\"page-agents\">\n    <section class=\"panel full\">\n      <h2>多智能体研究室</h2>\n      <p class=\"warn\">研究/建议用途 · 不可直接下单 · Bull/Bear 双通道保留</p>\n      <div id=\"agents-body\" class=\"primary-view\" data-primary-view=\"agents\"></div>\n      <button data-action=\"agents-run\" type=\"button\">运行多智能体研究</button>\n    </section>\n  </main>\n\n  <main class=\"layout hidden\" id=\"page-native\">\n    <section class=\"panel full\">\n      <h2>原生引擎 · vn.py / Qlib</h2>\n      <div id=\"native-body\" class=\"primary-view\" data-primary-view=\"native\"></div>\n      <div class=\"actions wrap\">\n        <button data-action=\"native-vnpy-accept\" type=\"button\">vn.py 原生验收</button>\n        <button data-action=\"native-qlib-accept\" type=\"button\">Qlib 原生验收</button>\n        <button id=\"btn-vnpy-start-native\" type=\"button\">启动 vn.py Runtime</button>\n        <button id=\"btn-qlib-baseline-native\" type=\"button\">运行 Qlib 基线</button>\n      </div>\n    </section>\n  </main>\n\n  <main class=\"layout hidden\" id=\"page-paper\">\n    <section class=\"panel full\">\n      <h2>模拟交易 · Paper</h2>\n      <div id=\"paper-pnl\" class=\"primary-view\" data-primary-view=\"paper-pnl\"></div>\n      <h3>持仓</h3>\n      <div id=\"paper-positions\"></div>\n      <h3>订单</h3>\n      <div id=\"paper-orders\"></div>\n      <div class=\"actions wrap\">\n        <button data-action=\"paper-start\" type=\"button\">启动 Paper</button>\n        <button data-action=\"paper-stop\" type=\"button\">停止 Paper</button>\n        <button data-action=\"paper-refresh\" type=\"button\">刷新状态</button>\n      </div>\n    </section>\n  </main>\n\n  <main class=\"layout hidden\" id=\"page-shadow\">\n    <section class=\"panel full\">\n      <h2>影子实盘 · Shadow</h2>\n      <p class=\"warn\">ZERO_REAL_ORDERS_SENT · 零真实订单</p>\n      <div id=\"shadow-status\" class=\"primary-view\" data-primary-view=\"shadow\"></div>\n      <h3>最近事件</h3>\n      <div id=\"shadow-events\"></div>\n      <div class=\"actions wrap\">\n        <button data-action=\"shadow-start\" type=\"button\">启动 Shadow</button>\n        <button data-action=\"shadow-stop\" type=\"button\">停止 Shadow</button>\n      </div>\n    </section>\n  </main>\n\n  <main class=\"layout hidden\" id=\"page-risk\">\n    <section class=\"panel full\">\n      <h2>风险中心</h2>\n      <div id=\"risk-detail\" class=\"primary-view\" data-primary-view=\"risk\"></div>\n      <div class=\"actions wrap\">\n        <button data-action=\"risk-check\" type=\"button\">风险自检</button>\n        <button data-action=\"halt\" type=\"button\" class=\"danger\">紧急停机</button>\n        <button data-action=\"reset-request\" type=\"button\">申请解除停机</button>\n        <button data-action=\"reset-confirm\" type=\"button\">确认解除停机</button>\n      </div>\n    </section>\n  </main>\n\n  <main class=\"layout hidden\" id=\"page-brokers\">\n    <section class=\"panel full\">\n      <h2>券商 Gateway 能力矩阵</h2>\n      <div id=\"gateway-list\" class=\"primary-view\" data-primary-view=\"brokers\"></div>\n      <div id=\"broker-checklist\" class=\"sub-panel\"></div>\n      <div class=\"actions wrap\">\n        <button data-action=\"broker-readonly\" type=\"button\">只读连接向导</button>\n      </div>\n      <p class=\"warn\">真实执行模式: MANUAL_CONFIRM_ONLY · Real Execution: DISABLED</p>\n    </section>\n  </main>\n\n  <footer class=\"footer\">\n    <span>PAPER_TRADING_ONLY · 真实资金交易已禁用 · QuantOS CN V4</span>\n    <span id=\"footer-version\" class=\"footer-version\">版本加载中…</span>\n    <span id=\"footer-build-warn\" class=\"build-warn hidden\">前后端 Build ID 不一致 — 请强制刷新 (Ctrl+Shift+R)</span>\n  </footer>\n\n  <script src=\"/portal/assets/api-client.js?v=11137e9-index.html:1781659794-app.js:1781659805-viewmodels.js:17\"></script>\n  <script src=\"/portal/assets/viewmodels.js?v=11137e9-index.html:1781659794-app.js:1781659805-viewmodels.js:17\"></script>\n  <script src=\"/portal/assets/ui-render.js?v=11137e9-index.html:1781659794-app.js:1781659805-viewmodels.js:17\"></script>\n  <script src=\"/portal/assets/action-registry.js?v=11137e9-index.html:1781659794-app.js:1781659805-viewmodels.js:17\"></script>\n  <script src=\"/portal/assets/app.js?v=11137e9-index.html:1781659794-app.js:1781659805-viewmodels.js:17\"></script>\n  <script src=\"/portal/assets/quantos.js?v=11137e9-index.html:1781659794-app.js:1781659805-viewmodels.js:17\"></script>\n</body>\n</html>\n"
