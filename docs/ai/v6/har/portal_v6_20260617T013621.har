          "content": {
            "size": 6016,
            "mimeType": "text/css; charset=utf-8",
            "compression": 0,
            "text": ".nav-tabs {\n  display: flex; flex-wrap: wrap; gap: 0.25rem; padding: 0.5rem 1rem;\n  background: #161b22; border-bottom: 1px solid var(--border);\n  position: sticky; top: 52px; z-index: 9;\n}\n.tab {\n  background: transparent; color: var(--muted); border: 1px solid transparent;\n  padding: 0.35rem 0.65rem; border-radius: 6px; cursor: pointer; font-size: 0.8rem;\n}\n.tab.active { background: var(--panel); color: var(--text); border-color: var(--border); }\n.hidden { display: none !important; }\n\n.login-overlay {\n  position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 100;\n  display: flex; align-items: center; justify-content: center;\n}\n.login-overlay.hidden { display: none !important; }\n.login-card {\n  background: var(--panel); border: 1px solid var(--border); border-radius: 12px;\n  padding: 2rem; min-width: 320px; max-width: 400px;\n}\n.login-card h1 { margin: 0 0 0.5rem; font-size: 1.1rem; }\n.login-card select { width: 100%; margin: 0.5rem 0 1rem; padding: 0.5rem; background: #0d1117; color: var(--text); border: 1px solid var(--border); border-radius: 6px; }\n.muted { color: var(--muted); font-size: 0.85rem; }\n.error { color: var(--danger); font-size: 0.85rem; }\n.btn-secondary { background: var(--panel); border: 1px solid var(--border); color: var(--text); }\nbutton.danger { background: var(--danger); }\n.actions.wrap { flex-wrap: wrap; }\n.action-log {\n  margin: 0 1rem; padding: 0.75rem; background: #21262d; border: 1px solid var(--border);\n  border-radius: 8px; max-width: 1400px; margin-left: auto; margin-right: auto;\n  color: var(--text);\n}\n.action-log-body { margin-top: 0.5rem; }\n.action-entry { padding: 0.6rem; border-radius: 6px; background: #0d1117; border: 1px solid var(--border); }\n.action-entry.fail { border-color: var(--danger); }\n.action-head { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin-bottom: 0.35rem; }\n.action-name { font-weight: 600; }\n.action-time { color: var(--muted); font-size: 0.75rem; }\n.action-summary { font-size: 0.9rem; }\n.action-run { font-size: 0.75rem; color: var(--muted); margin-top: 0.25rem; }\n.raw-details summary { cursor: pointer; color: var(--muted); font-size: 0.75rem; margin-top: 0.35rem; }\n.raw-json { font-size: 0.68rem; max-height: 120px; overflow: auto; background: #010409; padding: 0.5rem; border-radius: 4px; }\n\n.card-grid {\n  display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.75rem;\n}\n.stat-card {\n  background: #0d1117; border: 1px solid var(--border); border-radius: 8px; padding: 0.75rem;\n}\n.stat-card.tone-ok { border-color: var(--ok); }\n.stat-card.tone-warn { border-color: var(--warn); }\n.stat-card.tone-danger { border-color: var(--danger); }\n.stat-title { font-size: 0.72rem; color: var(--muted); margin-bottom: 0.25rem; }\n.stat-value { font-size: 1rem; font-weight: 600; }\n.stat-hint { font-size: 0.68rem; color: var(--muted); margin-top: 0.25rem; }\n\n.data-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; margin: 0.5rem 0; }\n.data-table th, .data-table td { border: 1px solid var(--border); padding: 0.4rem 0.55rem; text-align: left; }\n.data-table th { background: #161b22; color: var(--muted); font-weight: 600; }\n.data-table tbody tr:nth-child(even) { background: rgba(255,255,255,0.02); }\n\n.badge { display: inline-block; padding: 0.15rem 0.45rem; border-radius: 4px; font-size: 0.68rem; font-weight: 600; }\n.badge-ok { background: rgba(63,185,80,0.2); color: var(--ok); }\n.badge-warn { background: rgba(210,153,34,0.2); color: var(--warn); }\n.badge-danger { background: rgba(248,81,73,0.2); color: var(--danger); }\n.badge-default { background: var(--panel); color: var(--muted); }\n\n.empty-state { padding: 1rem; border: 1px dashed var(--border); border-radius: 8px; background: #0d1117; }\n.empty-reason { color: var(--muted); margin: 0.35rem 0; }\n.empty-fix { color: var(--accent); font-size: 0.8rem; }\n\n.kv-list { display: grid; grid-template-columns: max-content 1fr; gap: 0.35rem 1rem; font-size: 0.85rem; }\n.kv-list dt { color: var(--muted); }\n.kv-list dd { margin: 0; }\n\n.banner { padding: 0.5rem 0.75rem; border-radius: 6px; margin-bottom: 0.75rem; font-size: 0.85rem; }\n.banner-ok { background: rgba(63,185,80,0.15); border: 1px solid var(--ok); }\n.banner-warn { background: rgba(210,153,34,0.15); border: 1px solid var(--warn); }\n\n.blocker-list { list-style: none; padding: 0; margin: 0.5rem 0; }\n.blocker-item { margin: 0.35rem 0; }\n\n.agent-section { margin-bottom: 0.75rem; }\n.agent-section h3 { margin: 0 0 0.25rem; font-size: 0.85rem; color: var(--accent); }\n.agent-list { font-size: 0.82rem; }\n\n.footer-version { display: block; margin-top: 0.35rem; font-size: 0.68rem; }\n.build-warn { display: block; color: var(--danger); font-weight: 600; margin-top: 0.25rem; }\n.checklist { font-size: 0.82rem; padding-left: 1.2rem; }\n.sub-panel { margin: 0.75rem 0; }\n.report-list { font-size: 0.82rem; }\nh3 { font-size: 0.85rem; margin: 0.75rem 0 0.35rem; color: var(--muted); }\n.tag { font-size: 0.65rem; background: var(--warn); color: #000; padding: 0.1rem 0.35rem; border-radius: 4px; margin-left: 0.35rem; }\n\n/* V6 Job panel */\n.job-panel { border: 1px solid var(--border, #2a2f3a); border-radius: 8px; padding: 0.6rem; margin: 0.4rem 0; }\n.job-head { display: flex; gap: 0.6rem; align-items: center; font-size: 0.78rem; }\n.job-id { color: var(--muted); }\n.job-progress { background: #1b1f29; border-radius: 6px; height: 18px; margin: 0.45rem 0; overflow: hidden; }\n.job-progress-fill { background: linear-gradient(90deg,#2563eb,#22c55e); height: 100%; color: #fff; font-size: 0.68rem; text-align: center; line-height: 18px; transition: width 0.3s; min-width: 2ch; }\n.job-error { color: var(--danger, #ef4444); font-size: 0.78rem; margin-top: 0.3rem; }\n.job-artifacts, .job-events { font-size: 0.72rem; color: var(--muted); margin-top: 0.3rem; padding-left: 1rem; }\n.job-event { font-family: ui-monospace, monospace; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.badge-info { background: #2563eb; color: #fff; }\n"
