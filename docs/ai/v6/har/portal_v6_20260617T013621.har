            "text": ":root {\n  --bg: #0f1419;\n  --panel: #1a2332;\n  --text: #e6edf3;\n  --muted: #8b949e;\n  --accent: #3d8bfd;\n  --warn: #d29922;\n  --danger: #f85149;\n  --ok: #3fb950;\n  --border: #30363d;\n  font-family: -apple-system, BlinkMacSystemFont, \"PingFang SC\", \"Hiragino Sans GB\", \"Microsoft YaHei\", \"Noto Sans CJK SC\", \"IBM Plex Sans\", \"Segoe UI\", system-ui, sans-serif;\n}\n\n* { box-sizing: border-box; }\nbody { margin: 0; background: var(--bg); color: var(--text); min-height: 100vh; }\n\n.top-bar {\n  display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;\n  gap: 0.75rem; padding: 0.75rem 1rem; border-bottom: 1px solid var(--border);\n  background: #161b22; position: sticky; top: 0; z-index: 10;\n}\n.brand { font-weight: 600; letter-spacing: 0.02em; }\n.status-grid { display: flex; flex-wrap: wrap; gap: 0.4rem; }\n.pill {\n  font-size: 0.72rem; padding: 0.25rem 0.5rem; border-radius: 4px;\n  background: var(--panel); border: 1px solid var(--border); color: var(--muted);\n}\n.pill.kill { border-color: var(--danger); color: var(--danger); }\n\n.layout {\n  display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n  gap: 1rem; padding: 1rem; max-width: 1400px; margin: 0 auto;\n}\n.panel {\n  background: var(--panel); border: 1px solid var(--border); border-radius: 8px; padding: 1rem;\n}\n.panel.full { grid-column: 1 / -1; }\n.panel.sidecar { border-color: #484f58; }\nh2 { margin: 0 0 0.75rem; font-size: 0.95rem; font-weight: 600; }\n.mono { font-family: \"IBM Plex Mono\", ui-monospace, monospace; font-size: 0.8rem; line-height: 1.5; }\n.block { background: #0d1117; padding: 0.75rem; border-radius: 6px; border: 1px solid var(--border); }\n.small { margin-top: 0.5rem; max-height: 120px; overflow: auto; }\n.list { margin: 0; padding-left: 1.2rem; font-size: 0.85rem; }\n.warn { color: var(--warn); font-size: 0.8rem; margin: 0 0 0.5rem; }\n.actions { display: flex; gap: 0.5rem; margin-top: 0.75rem; }\nbutton {\n  background: var(--accent); color: #fff; border: none; padding: 0.45rem 0.75rem;\n  border-radius: 6px; cursor: pointer; font-size: 0.8rem;\n}\nbutton#btn-halt { background: var(--danger); }\nbutton:focus { outline: 2px solid var(--accent); outline-offset: 2px; }\n.footer { text-align: center; padding: 1rem; color: var(--muted); font-size: 0.75rem; }\n\n@media (max-width: 600px) {\n  .top-bar { flex-direction: column; align-items: flex-start; }\n}\n\n@media (prefers-color-scheme: light) {\n  :root {\n    --bg: #f6f8fa; --panel: #ffffff; --text: #1f2328; --muted: #656d76;\n    --border: #d0d7de;\n  }\n  .block { background: #f6f8fa; }\n  .top-bar { background: #ffffff; }\n}\n"
